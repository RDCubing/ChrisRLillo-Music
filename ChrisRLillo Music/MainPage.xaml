<Page
    x:Class="ChrisRLillo_Music.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ChrisRLillo_Music"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <x:String x:Key="ChevronGlyph">&#xE26B;</x:String>
        <Storyboard x:Name="FadeInStoryboard">

            <!-- Fade in Title -->
            <DoubleAnimation
            Storyboard.TargetName="TitleText"
            Storyboard.TargetProperty="Opacity"
            From="0" To="1"
            Duration="0:0:0.6"
            EnableDependentAnimation="True"/>

            <!-- Fade in Content (slight delay like Windows 8) -->
            <DoubleAnimation
            Storyboard.TargetName="ContentText"
            Storyboard.TargetProperty="Opacity"
            From="0" To="1"
            Duration="0:0:0.6"
            BeginTime="0:0:0.2"
            EnableDependentAnimation="True"/>

        </Storyboard>
        <Storyboard x:Name="SlideInStoryboard">

            <!-- Slide animation -->
            <DoubleAnimation
            Storyboard.TargetName="MainPanelTransform"
            Storyboard.TargetProperty="X"
            From="200" To="0"
            Duration="0:0:1.2"
            EnableDependentAnimation="True">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>


            <!-- Optional: subtle fade-in -->
            <DoubleAnimation
            Storyboard.TargetName="MainPanel"
            Storyboard.TargetProperty="Opacity"
            From="0" To="1"
            Duration="0:0:0.6"
            EnableDependentAnimation="True"/>

        </Storyboard>
        <Storyboard x:Name="ImageFadeStoryboard">

            <DoubleAnimation
        Storyboard.TargetName="RotatingImage"
        Storyboard.TargetProperty="Opacity"
        From="0" To="1"
        Duration="0:0:1.2"
        EnableDependentAnimation="True"/>

        </Storyboard>
        <Storyboard x:Name="Image2FadeStoryboard">

            <DoubleAnimation
        Storyboard.TargetName="RotatingImage2"
        Storyboard.TargetProperty="Opacity"
        From="0" To="1"
        Duration="0:0:1.2"
        EnableDependentAnimation="True"/>

        </Storyboard>

    </Page.Resources>

    <Grid>
        <Grid.Background>
            <ImageBrush Stretch="UniformToFill" ImageSource="ms-appx:///Assets/image-1138x759.png"/>
        </Grid.Background>
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition/>
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
            <!-- Mini player -->
        </Grid.RowDefinitions>

        <!-- More transparent colorful gradient overlay -->
        <Rectangle Grid.RowSpan="2"
           HorizontalAlignment="Stretch"
           VerticalAlignment="Stretch"
           Opacity="0.45">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">

                    <GradientStop Color="#661E3C72" Offset="0.0"/>
                    <!-- deep blue (transparent) -->
                    <GradientStop Color="#662A5298" Offset="0.25"/>
                    <!-- blue -->
                    <GradientStop Color="#666A11CB" Offset="0.5"/>
                    <!-- purple -->
                    <GradientStop Color="#662575FC" Offset="0.75"/>
                    <!-- bright blue -->
                    <GradientStop Color="#6600C6FF" Offset="1.0"/>
                    <!-- cyan -->

                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Header -->
        <TextBlock
        Grid.Row="0"
        Text="ChrisRLillo Music"
        Margin="50"
        Style="{StaticResource HeaderTextBlockStyle}" />

        <!-- Content Area with horizontal scroll only -->
        <ScrollViewer
    Grid.Row="1"
    ZoomMode="Disabled"
    HorizontalScrollMode="Auto"
    HorizontalScrollBarVisibility="Auto"
    VerticalScrollMode="Disabled"
    VerticalScrollBarVisibility="Disabled">

            <StackPanel x:Name="MainPanel" Orientation="Horizontal" HorizontalAlignment="Left" Margin="20" >
                <StackPanel.RenderTransform>
                    <TranslateTransform x:Name="MainPanelTransform" X="200"/>
                </StackPanel.RenderTransform>
                <!-- Welcome Section -->
                <Grid Width="400" Margin="50,0,40,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Title -->
                        <RowDefinition Height="Auto"/>
                        <!-- Description -->
                        <RowDefinition Height="Auto"/>
                        <!-- Links header -->
                        <RowDefinition Height="*"/>
                        <!-- Links list (fills space) -->
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <TextBlock Grid.Row="0"
               Text="Welcome to the new ChrisRLillo Music App!"
               FontSize="36"
               FontWeight="Light"
               Foreground="White"
               Margin="0,0,0,10"
               TextWrapping="Wrap"/>

                    <!-- Description -->
                    <TextBlock Grid.Row="1"
               Text="Discover the latest songs, updates, and exclusive content from ChrisRLillo. Explore, enjoy, and stay tuned for more!"
               FontSize="16"
               FontWeight="Light"
               Foreground="White"
               Margin="0,0,0,25"
               TextWrapping="Wrap"/>

                    <!-- Links Header -->
                    <TextBlock Grid.Row="2"
               Text="Links"
               FontSize="36"
               FontWeight="Light"
               Foreground="White"
               Margin="0,0,0,20"/>

                    <!-- Links (now stretches properly) -->
                    <ScrollViewer Grid.Row="3"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

                        <StackPanel>
                            <HyperlinkButton Content="Bandcamp"
                             NavigateUri="https://chrisrlillo.bandcamp.com/" />

                            <HyperlinkButton Content="YouTube"
                             NavigateUri="https://www.youtube.com/channel/UCuyJDal7T1UhCr-zmQ42orw" />

                            <HyperlinkButton Content="Patreon"
                             NavigateUri="https://www.patreon.com/chrisbrutalagresion" />

                            <HyperlinkButton Content="Streamlabs"
                             NavigateUri="https://streamlabs.com/chrisbrutalagresion/tip" />

                            <HyperlinkButton Content="Discord Server"
                             NavigateUri="https://discord.gg/DV4zDT8QX5" />

                            <HyperlinkButton Content="Linktree"
                             NavigateUri="https://linktr.ee/chrisrlillo" />

                            <HyperlinkButton Content="Twitch"
                             NavigateUri="https://www.twitch.tv/chrisrlillo" />
                        </StackPanel>

                    </ScrollViewer>
                </Grid>
                <Grid Width="500" Margin="50,0,40,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Title -->
                        <RowDefinition Height="Auto"/>
                        <!-- Subtitle -->
                        <RowDefinition Height="*"/>
                        <!-- List fills space -->
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <TextBlock Text="Songs"
               FontSize="36"
               FontWeight="Light"
               Foreground="White"
               Margin="0,0,0,10"/>

                    <!-- Subtitle -->
                    <TextBlock Grid.Row="1"
               Text="Powered by GDC Media Player"
               FontSize="16"
               FontWeight="Light"
               Foreground="White"
               Margin="0,0,0,25"/>

                    <!-- THIS NOW STRETCHES FULL HEIGHT -->
                    <ListView Grid.Row="2"
              x:Name="SongsListView"
              ItemsSource="{Binding}"
              IsItemClickEnabled="True"
              ItemClick="SongsListView_ItemClick"
              SelectionMode="None">

                        <ListView.ItemTemplate>
                            <DataTemplate>

                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Thumbnail -->
                                    <Image Source="{Binding ImageUrl}"
                           Width="75"
                           Height="75"
                           Stretch="UniformToFill"/>

                                    <!-- Text -->
                                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="10,0,0,0">

                                        <TextBlock Text="{Binding Title}"
                                   FontSize="20"
                                   Foreground="White"
                                                   FontWeight="Light"
                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Text="{Binding Artist}"
                                   FontSize="16"
                                   Foreground="#BFFFFFFF"
                                                   FontWeight="Light"
                                   TextTrimming="CharacterEllipsis"/>

                                    </StackPanel>

                                </Grid>

                            </DataTemplate>
                        </ListView.ItemTemplate>

                    </ListView>
                </Grid>

                <Grid Width="620" Margin="50,0,40,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Header -->
                        <RowDefinition Height="*"/>
                        <!-- Content fills space -->
                    </Grid.RowDefinitions>

                    <!-- Section Header -->
                    <TextBlock Text="Suggested"
               FontSize="36"
               FontWeight="Light"
               Foreground="White"
               Margin="0,0,0,20"/>

                    <!-- Content (scrolls if needed) -->
                    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

                        <StackPanel>

                            <!-- First card -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Image Source="ms-appx:///Assets/portada_3000_1.png"
                       Width="200"
                       Height="200"
                       Stretch="UniformToFill"/>

                                <StackPanel Grid.Column="1"
                            Margin="10,0,0,0">

                                    <TextBlock Text="PINNED: Love &amp; Hate Album"
                               FontSize="26"
                               Foreground="White"
                                               FontWeight="Light"
                               Margin="0,0,0,10"
                               TextWrapping="Wrap"/>

                                    <TextBlock Text="Love &amp; Hate (2025) is the debut album by Chilean rock/metal artist Chris R. Lillo, blending intense riffs with personal, bilingual songwriting that explores love, pain, and emotional struggle with raw energy and passion."
                               FontSize="16"
                               Foreground="White"
                                               FontWeight="Light"
                               TextWrapping="Wrap"/>

                                </StackPanel>
                            </Grid>

                            <!-- Second card -->
                            <StackPanel Margin="0,0,0,20">

                                <TextBlock Text="Loading... / Cargando..."
                           FontSize="26"
                                           FontWeight="Light"
                           Foreground="White"
                           Margin="0,0,0,10"
                           TextWrapping="Wrap"
                           x:Name="TitleText"/>

                                <TextBlock Text="Loading content... / Cargando contenido..."
                           FontSize="16"
                                           FontWeight="Light"
                           Foreground="White"
                           TextWrapping="Wrap"
                           x:Name="ContentText"/>

                            </StackPanel>

                        </StackPanel>

                    </ScrollViewer>
                </Grid>


                <Grid Width="Auto" Margin="50,0,40,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0"
        Background="Transparent"
        BorderThickness="0"
        HorizontalAlignment="Left"
        Margin="0,0,0,20"
        Click="FeaturedVideos_Click">

                        <StackPanel Orientation="Horizontal"
            VerticalAlignment="Center">

                            <!-- Text -->
                            <TextBlock Text="Featured Videos"
               FontSize="36"
                                       x:Uid="ProjectsSection"
               FontWeight="Light"
               Foreground="White"
               VerticalAlignment="Center"/>

                            <!-- Chevron -->
                            <TextBlock Text="{StaticResource ChevronGlyph}"
               FontFamily="Segoe MDL2 Assets"
               FontSize="20"
               Foreground="White"
               VerticalAlignment="Center"
               Margin="10,0,0,0"/>
                        </StackPanel>

                    </Button>

                    <GridView Grid.Row="1"
          ItemsSource="{Binding FeaturedVideosLimited}"
          ItemClick="GridView_ItemClick"
          IsItemClickEnabled="True"
          SelectionMode="None"
          ScrollViewer.HorizontalScrollMode="Enabled"
          ScrollViewer.HorizontalScrollBarVisibility="Auto"
          ScrollViewer.VerticalScrollMode="Disabled"
          ScrollViewer.VerticalScrollBarVisibility="Disabled">

                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid
                Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>

                        <GridView.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="240" Height="135">
                                    <Border Background="{ThemeResource ListViewItemPlaceholderBackgroundThemeBrush}">
                                        <Image Source="{Binding ImagePath}" Stretch="UniformToFill"/>
                                    </Border>

                                    <Border VerticalAlignment="Bottom"
                        Height="48"
                        Background="#CC000000">

                                        <StackPanel Margin="8,4,8,4">
                                            <TextBlock Text="{Binding Title}"
                                   Foreground="White"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"/>

                                            <TextBlock Text="{Binding Subtitle}"
                                   Foreground="#BFFFFFFF"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </GridView.ItemTemplate>

                    </GridView>

                </Grid>
                <Grid Width="Auto" Margin="50,0,40,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0"
        Background="Transparent"
        BorderThickness="0"
        HorizontalAlignment="Left"
        Margin="0,0,0,20"
        Click="Albums_Click">

                        <StackPanel Orientation="Horizontal"
            VerticalAlignment="Center">

                            <!-- Text -->
                            <TextBlock Text="Albums and Singles"
               FontSize="36"
                                       x:Uid="ProjectsSection"
               FontWeight="Light"
               Foreground="White"
               VerticalAlignment="Center"/>

                            <!-- Chevron -->
                            <TextBlock Text="{StaticResource ChevronGlyph}"
               FontFamily="Segoe MDL2 Assets"
               FontSize="20"
               Foreground="White"
               VerticalAlignment="Center"
               Margin="10,0,0,0"/>
                        </StackPanel>

                    </Button>

                    <GridView Grid.Row="1"
          ItemsSource="{Binding AlbumsLimited}"
          ItemClick="GridView1_ItemClick"
          IsItemClickEnabled="True"
          SelectionMode="None"
          ScrollViewer.HorizontalScrollMode="Enabled"
          ScrollViewer.HorizontalScrollBarVisibility="Auto"
          ScrollViewer.VerticalScrollMode="Disabled"
          ScrollViewer.VerticalScrollBarVisibility="Disabled">

                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid
                Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>

                        <GridView.ItemTemplate>
                            <DataTemplate>

                                <Grid Width="150" Height="150">

                                    <Border Background="{ThemeResource ListViewItemPlaceholderBackgroundThemeBrush}">
                                        <Image Source="{Binding ImagePath}"
                           Stretch="UniformToFill"/>
                                    </Border>

                                    <Border VerticalAlignment="Bottom"
                        Background="#AA000000"
                        Height="50">

                                        <StackPanel Margin="6,2,6,2">

                                            <TextBlock Text="{Binding Title}"
                                   Foreground="White"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"/>

                                            <TextBlock Text="{Binding Subtitle}"
                                   Foreground="#CCFFFFFF"
                                   FontSize="10"
                                   TextTrimming="CharacterEllipsis"/>

                                        </StackPanel>

                                    </Border>

                                </Grid>

                            </DataTemplate>
                        </GridView.ItemTemplate>

                    </GridView>

                </Grid>
                <Grid Width="400" Margin="50,0,40,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <TextBlock Text="Discography"
               FontSize="36"
               FontWeight="Light"
               Foreground="White"
               Margin="0,0,0,20"/>

                    <!-- Scrollable content -->
                    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

                        <StackPanel>

                            <!-- 2023 -->
                            <TextBlock Text="2023: The Beginning"
                       FontSize="26"
                       Foreground="White"
                       FontWeight="Light"
                       Margin="0,0,0,30"
                       TextWrapping="Wrap"/>

                            <TextBlock Text="- &quot;Don't Be Scared&quot; (acoustic single): An emotional and sincere acoustic song narrating a heartbreaking story."
                       FontSize="16"
                       Foreground="White"
                       Margin="0,0,0,15"
                       TextWrapping="Wrap"/>

                            <TextBlock Text="- &quot;White Balcony&quot; (rock single): A powerful rock song with energetic vocals and deeply emotional lyrics, accompanied by a well-received 80s-style live music video."
                       FontSize="16"
                       Foreground="White"
                       Margin="0,0,0,30"
                       TextWrapping="Wrap"/>

                            <!-- 2024 -->
                            <TextBlock Text="2024: The EP Illusions"
                       FontSize="26"
                       Foreground="White"
                       FontWeight="Light"
                       Margin="0,0,0,30"
                       TextWrapping="Wrap"/>

                            <TextBlock Text="- EP Release: Showcasing Chris's musical versatility, the EP includes three new songs, two alternate versions with orchestral arrangements, and an instrumental."
                       FontSize="16"
                       Foreground="White"
                       Margin="0,0,0,15"
                       TextWrapping="Wrap"/>

                            <TextBlock Text="- Music Videos: Each song is complemented by meticulously produced music videos that enhance the listening experience with impactful visual narratives."
                       FontSize="16"
                       Foreground="White"
                       Margin="0,0,0,30"
                       TextWrapping="Wrap"/>

                            <!-- 2025 -->
                            <TextBlock Text="2025: Ghostly Touch"
                       FontSize="26"
                       Foreground="White"
                       FontWeight="Light"
                       Margin="0,0,0,30"
                       TextWrapping="Wrap"/>

                            <TextBlock Text="- Single: Released on January 6, 2025."
                       FontSize="16"
                       Foreground="White"
                       Margin="0,0,0,15"
                       TextWrapping="Wrap"/>

                            <TextBlock Text="- Music Video: The music video for &quot;Ghostly Touch&quot; was filmed at the Santo Tomás Center in Talca with a professional team, delivering a deeply emotional audiovisual experience."
                       FontSize="16"
                       Foreground="White"
                       TextWrapping="Wrap"/>

                        </StackPanel>

                    </ScrollViewer>

                </Grid>

                <Grid Width="620" Margin="50,0,40,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <TextBlock Text="About Chris"
               FontSize="36"
               FontWeight="Light"
               Foreground="White"
               Margin="0,0,0,10"/>

                    <!-- Content -->
                    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

                        <StackPanel>

                            <!-- Card 1 -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Image x:Name="RotatingImage" Source="ms-appx:///Assets/1.jpg"
                       Width="200"
                       Height="200"
                       Stretch="UniformToFill"/>

                                <TextBlock Grid.Column="1"
                           Margin="10,0,0,0"
                           Text="Chris R. Lillo is a rock and heavy metal artist from Chile, known for his energetic style and ability to blend powerful melodies with deep lyrics. Immersed in the music scene since the age of 13, Chris draws inspiration from rock classics and contemporary metal icons, creating a unique sound that captivates fans of both genres."
                           FontSize="16"
                           Foreground="White"
                           TextWrapping="Wrap"/>
                            </Grid>

                            <!-- Card 2 -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Image x:Name="RotatingImage2" Source="ms-appx:///Assets/2.jpg"
                       Width="200"
                       Height="200"
                       Stretch="UniformToFill"/>

                                <TextBlock Grid.Column="1"
                           Margin="10,0,0,0"
                           Text="Chris's dedication to authenticity and artistic expression is reflected in every note he plays and every word he sings."
                           FontSize="16"
                           Foreground="White"
                           TextWrapping="Wrap"/>
                            </Grid>

                        </StackPanel>

                    </ScrollViewer>

                </Grid>
            </StackPanel>

        </ScrollViewer>
        <Grid Grid.Row="2"
      Height="80"
      Background="#DD111111">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <!-- LEFT -->
                <ColumnDefinition Width="*"/>
                <!-- CENTER (MediaElement) -->
                <ColumnDefinition Width="Auto"/>
                <!-- RIGHT -->
            </Grid.ColumnDefinitions>

            <!-- ================= LEFT: Song Info ================= -->
            <Grid Grid.Column="0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Album Image -->
                <Image x:Name="MiniPlayerImage"
               Grid.Column="0"
               Width="80"
               Height="80"
               Stretch="UniformToFill"/>

                <!-- Title + Artist -->
                <StackPanel Grid.Column="1"
                    VerticalAlignment="Center"
                    Margin="10,0,0,0">

                    <TextBlock x:Name="MiniPlayerTitle"
                       Text="Nothing Playing"
                       FontSize="16"
                       Foreground="White"
                       TextTrimming="CharacterEllipsis"/>

                    <TextBlock x:Name="MiniPlayerArtist"
                       Text="---"
                       FontSize="12"
                       Foreground="#BFFFFFFF"
                       TextTrimming="CharacterEllipsis"/>
                </StackPanel>

            </Grid>

            <!-- ================= CENTER: MEDIA ELEMENT ================= -->
            <Grid Grid.Column="1"
          VerticalAlignment="Center"
          HorizontalAlignment="Stretch">

                <MediaElement x:Name="Player"
                      AutoPlay="False"
                      AreTransportControlsEnabled="True"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"/>
            </Grid>

            <!-- ================= RIGHT: CONTROLS ================= -->
            <StackPanel Grid.Column="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Center">

                <Button Content="Prev"
                Width="Auto" Height="40"
                Margin="0,0,4,0"
                Click="Prev_Click"/>

                <Button x:Name="PlayPauseButton"
                Content="Play"
                Width="Auto" Height="40"
                Margin="0,0,4,0"
                Click="PlayPause_Click"/>

                <Button Content="Next"
                Width="Auto" Height="40"
                Click="Next_Click"/>

            </StackPanel>

        </Grid>
    </Grid>
</Page>
