<Page
    x:Name="pageRoot"
    x:Class="ChrisRLillo_Music.Albums"
    DataContext="{Binding DefaultViewModel, RelativeSource={RelativeSource Self}}"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ChrisRLillo_Music"
    xmlns:common="using:ChrisRLillo_Music.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- TODO: Delete this line if the key AppName is declared in App.xaml -->
    </Page.Resources>

    <!--
        This grid acts as a root panel for the page that defines two rows:
        * Row 0 contains the back button and page title
        * Row 1 contains the rest of the page layout
    -->
    <Grid>
        <Grid.Background>
            <ImageBrush Stretch="UniformToFill" ImageSource="ms-appx:///Assets/image-1138x759.png"/>
        </Grid.Background>
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition/>
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="140"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- More transparent colorful gradient overlay -->
        <Rectangle Grid.RowSpan="2"
           HorizontalAlignment="Stretch"
           VerticalAlignment="Stretch"
           Opacity="0.45">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">

                    <GradientStop Color="#661E3C72" Offset="0.0"/>
                    <!-- deep blue (transparent) -->
                    <GradientStop Color="#662A5298" Offset="0.25"/>
                    <!-- blue -->
                    <GradientStop Color="#666A11CB" Offset="0.5"/>
                    <!-- purple -->
                    <GradientStop Color="#662575FC" Offset="0.75"/>
                    <!-- bright blue -->
                    <GradientStop Color="#6600C6FF" Offset="1.0"/>
                    <!-- cyan -->

                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Back button and page title -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Button x:Name="backButton" Margin="39,59,39,0" Command="{Binding NavigationHelper.GoBackCommand, ElementName=pageRoot}"
                        Style="{StaticResource NavigationBackButtonNormalStyle}"
                        VerticalAlignment="Top"
                        AutomationProperties.Name="Back"
                        AutomationProperties.AutomationId="BackButton"
                        AutomationProperties.ItemType="Navigation Button"/>
            <TextBlock x:Name="pageTitle" Text="Albums and Singles" Style="{StaticResource HeaderTextBlockStyle}" Grid.Column="1" 
                        IsHitTestVisible="false" TextWrapping="NoWrap" VerticalAlignment="Bottom" Margin="0,0,30,40"/>
        </Grid>
        <Grid Grid.Row="1">
            <ScrollViewer
        HorizontalScrollMode="Auto"
        HorizontalScrollBarVisibility="Auto"
        VerticalScrollMode="Disabled"
        VerticalScrollBarVisibility="Disabled"
        ZoomMode="Disabled">
                <GridView
          ItemsSource="{Binding AlbumItems}"
          ItemClick="GridView1_ItemClick"
          IsItemClickEnabled="True"
          SelectionMode="None"
                    Margin="40">

                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid
                Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>

                    <GridView.ItemTemplate>
                        <DataTemplate>

                            <Grid Width="200" Height="200">

                                <Border Background="{ThemeResource ListViewItemPlaceholderBackgroundThemeBrush}">
                                    <Image Source="{Binding ImagePath}"
                           Stretch="UniformToFill"/>
                                </Border>

                                <Border VerticalAlignment="Bottom"
                        Background="#AA000000"
                        Height="50">

                                    <StackPanel Margin="6,2,6,2">

                                        <TextBlock Text="{Binding Title}"
                                   Foreground="White"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Text="{Binding Subtitle}"
                                   Foreground="#CCFFFFFF"
                                   FontSize="10"
                                   TextTrimming="CharacterEllipsis"/>

                                    </StackPanel>

                                </Border>

                            </Grid>

                        </DataTemplate>
                    </GridView.ItemTemplate>

                </GridView>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
